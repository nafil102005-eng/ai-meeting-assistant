{
  "manifest_version": 3,
  "name": "AI Meeting Assistant Recorder",
  "version": "1.0.0",
  "description": "Capture live meeting voice transcripts, view summaries, and sync directly with Neon DB.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
